{
  "name": "@deliverect/galaxy-styles",
  "version": "2.3.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "postbuild": "cp src/typekit.css dist/typekit.css",
    "dev": "tsc --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "import": "./dist/typekit.css",
      "require": "./dist/typekit.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Deliverect/Galaxy.git"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/recipes": "^0.5.0",
    "@vanilla-extract/sprinkles": "^1.6.1"
  }
}
