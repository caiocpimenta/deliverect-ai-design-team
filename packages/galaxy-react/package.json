{
  "name": "@deliverect/galaxy-react",
  "version": "2.5.0",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "storybook dev -p 6006"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./css": {
      "types": "./dist/galaxy-react.css.d.ts",
      "import": "./dist/galaxy-react.css",
      "require": "./dist/galaxy-react.css"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:Deliverect/Galaxy.git"
  },
  "peerDependencies": {
    "react": ">=17.x || >=18.x",
    "react-dom": ">=17.x || >=18.x"
  },
  "devDependencies": {
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.3",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vanilla-extract/vite-plugin": "^3.8.2",
    "@vitejs/plugin-react": "^4.0.3",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-storybook": "^10.3.5",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "react-icons": "^4.10.1",
    "rollup-preserve-directives": "^1.1.1",
    "storybook": "^10.3.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.2.3",
    "vite-plugin-externalize-deps": "^0.8.0",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@deliverect/galaxy-styles": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/dynamic": "^2.1.0",
    "@vanilla-extract/recipes": "^0.5.0",
    "@vanilla-extract/sprinkles": "^1.6.1",
    "cmdk": "^0.2.1",
    "match-sorter": "^6.3.4",
    "react-day-picker": "^9.1.4",
    "react-intersection-observer": "^9.13.1"
  }
}
